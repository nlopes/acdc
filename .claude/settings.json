{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|MultiEdit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "jq -e '.tool_input.file_path | test(\"\\.rs$\")' > /dev/null && cargo fmt --all || exit 0"
          }
        ]
      }
    ]
  }
}
